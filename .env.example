# Copy this file to ~/.minion/.env and adjust as needed.
# All values shown are the defaults — only override what you want to change.

# Model to use (must be pulled in Ollama first: ollama pull <model>)
MINION_MODEL=qwen3:8b

# Ollama's OpenAI-compatible endpoint
MINION_OLLAMA_BASE_URL=http://localhost:11434/v1

# Data directory for the SQLite database and local config
MINION_DATA_DIR=~/.minion

# Tool feature flags (true/false)
MINION_ENABLE_WEB_SEARCH=true
MINION_ENABLE_SHELL=false      # opt-in — shell access is powerful, enable deliberately
MINION_ENABLE_FILESYSTEM=true
MINION_ENABLE_GIT=true
