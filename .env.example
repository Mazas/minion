# Copy this file to ~/.minion/.env and adjust as needed.
# All values shown are the defaults — only override what you want to change.

# ── Models ────────────────────────────────────────────────────────────────────

# Fast orchestrator — handles routing, simple tasks, memory, search
MINION_ORCHESTRATOR_MODEL=qwen3:4b

# Specialist model map (JSON). Keys are role names the agent uses when delegating.
# Add or change roles here without touching code.
MINION_DELEGATE_MODELS='{"reasoning":"qwen3:8b","code":"qwen2.5-coder:7b"}'

# Ollama endpoint (OpenAI-compatible)
MINION_OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Memory ────────────────────────────────────────────────────────────────────

# Embedding model for semantic (vector) memory search
MINION_EMBED_MODEL=nomic-embed-text

# Set false to disable vector search and use FTS5 keyword search only
MINION_ENABLE_SEMANTIC_SEARCH=true

# Days before stale memories are soft-deleted (importance >= 4 is always spared)
MINION_MEMORY_DECAY_CONTEXT_DAYS=30
MINION_MEMORY_DECAY_PROJECT_DAYS=90

# ── Storage ───────────────────────────────────────────────────────────────────

MINION_DATA_DIR=~/.minion

# ── Tool feature flags ────────────────────────────────────────────────────────

MINION_ENABLE_WEB_SEARCH=true
MINION_ENABLE_SHELL=false      # opt-in — enable deliberately
MINION_ENABLE_FILESYSTEM=true
MINION_ENABLE_GIT=true

# ── Search ────────────────────────────────────────────────────────────────────

MINION_SEARCH_PROVIDER=duckduckgo
